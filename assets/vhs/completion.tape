# lore completion — VHS Tape
# Generate: vhs assets/vhs/completion.tape
# Does NOT need demo project

Output docs/assets/vhs/completion.gif

Set Shell "bash"
Set FontSize 15
Set Width 1000
Set Height 500
Set Padding 16
Set Theme "Dracula"
Set TypingSpeed 60ms
Set CursorBlink false

Hide
Type "clear"
Enter
Sleep 500ms
Show

# Generate zsh completion
Type "lore completion zsh | head -20"
Enter
Sleep 3s
