# Lore configuration — shared with team (commit this file)
# See: https://github.com/GreyCoderK/lore/blob/main/docs/guides/configuration.md
language: "fr"

ai:
  provider: "anthropic"       # anthropic, openai, ollama
  model: "claude-sonnet-4-6"  # model name (e.g., claude-sonnet-4-20250514, llama3.2)
  timeout: 60s
angela:
  max_tokens: 16000  # bumped for review on larger corpus

templates:
  dir: .lore/templates

hooks:
  post_commit: false
  star_prompt: true
  star_prompt_after: 5
  amend_prompt: true     # Ask "Document this change?" on git commit --amend

notification:
  mode: silent           # auto, terminal, dialog, notify, silent
  disabled_envs: []
  amend: true            # Enable notifications for amend commits

output:
  format: markdown
  dir: .lore/docs

decision:
  threshold_full: 60
  threshold_reduced: 35
  threshold_suggest: 15
  always_ask: [feat, breaking]
  always_skip: [docs, style, ci, build]
  learning: true
  learning_min_commits: 20
